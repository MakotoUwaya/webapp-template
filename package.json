{
  "name": "webapp-template",
  "version": "0.0.1",
  "description": "tutorial project",
  "private": true,
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "lint-staged": "16.4.0",
    "ts-node": "10.9.2",
    "turbo": "2.9.6",
    "typescript": "6.0.3"
  },
  "scripts": {
    "prepare": "git config --local core.hooksPath .githook || echo 'Can not set git hooks' ",
    "react": "pnpm --filter react-vite",
    "vue": "pnpm --filter vue3-vite",
    "check": "turbo run lint build test",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "test": "turbo run test",
    "test:updateSnapshot": "turbo run test:updateSnapshot",
    "build": "turbo run build"
  },
  "packageManager": "pnpm@10.33.2",
  "workspaces": [
    "packages/*"
  ],
  "pnpm": {
    "overrides": {
      "protobufjs": "7.5.6",
      "test-exclude": "7.0.2",
      "shelljs": "0.10.0",
      "glob": "13.0.6"
    }
  }
}
