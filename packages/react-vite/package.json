{
  "name": "react-vite",
  "version": "0.0.1",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "prepare": "git config --local core.hooksPath .githook || echo 'Can not set git hooks' ",
    "format": "biome format ./src --write",
    "lint": "biome lint ./src --files-ignore-unknown=true",
    "lint:fix": "biome check --apply ./src --files-ignore-unknown=true",
    "dev": "vite",
    "dev:emulator": "vite --mode emulator",
    "build": "tsc --noEmit && vite build",
    "analyze": "ANALYZE=true pnpm build",
    "serve": "vite preview",
    "test": "jest",
    "test:updateSnapshot": "pnpm test -- -u",
    "emulators:start": "pnpm exec firebase emulators:start --import=./firebase/firestore-data",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@emotion/is-prop-valid": "1.4.0",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@mui/icons-material": "9.0.0",
    "@mui/material": "9.0.0",
    "@mui/x-data-grid": "9.0.2",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-firebase-hooks": "5.1.1",
    "react-router-dom": "7.14.2"
  },
  "devDependencies": {
    "@mdx-js/preact": "3.1.1",
    "@storybook/addon-links": "10.3.5",
    "@storybook/builder-vite": "10.3.5",
    "@storybook/react": "10.3.5",
    "@storybook/react-vite": "10.3.5",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/jest": "30.0.0",
    "@types/node": "24.12.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "esbuild-register": "3.6.0",
    "firebase": "12.12.1",
    "jest": "30.3.0",
    "jest-environment-jsdom": "30.3.0",
    "jest-resolve": "30.3.0",
    "jest-watch-typeahead": "3.0.1",
    "prop-types": "15.8.1",
    "rc": "1.2.8",
    "rollup-plugin-visualizer": "7.0.1",
    "storybook": "10.3.5",
    "ts-jest": "29.4.9",
    "typescript": "6.0.3",
    "vite": "8.0.9"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead"
    ],
    "development": [
      "last 1 chrome version"
    ]
  }
}
